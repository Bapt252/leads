# France Travail — OAuth2 client credentials
# https://francetravail.io → créer une app pour obtenir ces valeurs
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# Indeed : pas d'API publique officielle pour la recherche d'offres.
# Approche à décider (scraping, SerpAPI, flux RSS...) à la prochaine session.
# INDEED_API_KEY=

# LinkedIn : pas d'API publique pour les offres.
# Approche à décider (scraping avec session cookie, API tierce...) à la prochaine session.
# LINKEDIN_SESSION_COOKIE=
