# URL du Worker Cloudflare qui proxifie l'API France Travail.
# Obtenue après `cd worker && npx wrangler deploy`.
# Format : https://leads-france-travail.<ton-sous-domaine>.workers.dev
FRANCE_TRAVAIL_WORKER_URL=

# Secret partagé entre cette app et le Worker.
# Doit matcher la valeur définie côté Worker via `npx wrangler secret put SHARED_API_KEY`.
# Génère-le avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FRANCE_TRAVAIL_WORKER_KEY=

# Indeed : pas d'API publique officielle pour la recherche d'offres.
# Approche à décider (scraping, SerpAPI, flux RSS...) à la prochaine session.
# INDEED_API_KEY=

# LinkedIn : pas d'API publique pour les offres.
# Approche à décider (scraping avec session cookie, API tierce...) à la prochaine session.
# LINKEDIN_SESSION_COOKIE=
